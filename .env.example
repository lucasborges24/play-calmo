EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_EAS_PROJECT_ID=
# Background playback gate: off | pip | full
# off  = playback pauses on background (default, compliant)
# pip  = auto-enter Picture-in-Picture on background (visually compliant)
# full = pip + audio continues with screen locked (TOS risk, see docs/playback.md)
EXPO_PUBLIC_BACKGROUND_PLAYBACK=off
